{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Euchre Game Notation (EGN)",
  "description": "JSON Schema for validating Euchre Game Notation (.egn) files.",
  "type": "object",
  "properties": {
    "fileType": {
      "type": "string",
      "const": "Euchre Game Notation"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "matchId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "players": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "maxItems": 4,
          "description": "Array of 1 to 4 player names, starting with Player 0 and proceeding clockwise."
        },
        "initialScore": {
          "type": "array",
          "items": { "type": "integer" },
          "minItems": 2,
          "maxItems": 2,
          "description": "Initial team scores. [Team 0/2 Score, Team 1/3 Score]."
        },
        "date": {
          "type": "string",
          "format": "date-time",
          "description": "Date and time when the game was played."
        },
        "ruleset": {
            "type": "object",
            "properties": {
                "std": { "type": "boolean", "default": true },
                "min_rank": { "type": "integer", "default": 9 },
                "canadian": { "type": "boolean", "default": false },
                "loner_lead": { "type": "string", "enum": ["LEFT_OF_DEALER", "LEFT_OF_LONER"], "default": "LEFT_OF_DEALER" },
                "farmers": { "type": "boolean", "default": false },
                "partners_best": { "type": "boolean", "default": false },
                "go_under": { "type": "boolean", "default": false },
                "joker": { "type": "boolean", "default": false },
                "allow_no_trump": { "type": "boolean", "default": false }
            }
        }
      },
      "required": ["players", "initialScore"]
    },
    "deals": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "dealNumber": { "type": "integer", "minimum": 0 },
          "initialState": {
            "type": "object",
            "properties": {
              "dealer": {
                "type": "integer",
                "minimum": 0,
                "maximum": 3
              },
              "upCard": { "$ref": "#/definitions/card" },
              "kitty": { "$ref": "#/definitions/card_list" },
              "player_cards": {
                "type": "array",
                "items": { "$ref": "#/definitions/card_list" }
              }
            },
            "required": ["dealer", "upCard"]
          },
          "phases": {
            "type": "array",
            "minItems": 1,
            "maxItems": 2,
            "items": {
              "oneOf": [
                { "$ref": "#/definitions/biddingPhase" },
                { "$ref": "#/definitions/trickPlayPhase" }
              ]
            }
          }
        },
        "required": ["dealNumber", "initialState", "phases"]
      }
    }
  },
  "required": ["fileType", "version", "metadata", "deals"],
  "definitions": {
    "card": {
      "type": "string",
      "pattern": "^([78N9TJQKAX][SsHhCcDdxtngh]|[LRB])$"
    },
    "card_list": {
      "type": "array",
      "items": { "$ref": "#/definitions/card" }
    },
    "biddingPhase": {
      "type": "object",
      "required": ["phaseNumber", "type", "calls", "isAlone"],
      "properties": {
        "phaseNumber": { "type": "integer" },
        "type": { "const": "EUCHRE_BIDDING" },
        "calls": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": { "type": "string", "enum": ["Pass", "Order", "s", "h", "d", "c", "n", "x"] }
        },
        "isAlone": { "type": "boolean" },
        "discard": { "$ref": "#/definitions/card" },
        "card_exchanges": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "sender": { "type": "integer", "minimum": 0, "maximum": 3 },
              "receiver": { "type": "integer", "minimum": 0, "maximum": 3 },
              "cards": { "$ref": "#/definitions/card_list" }
            },
            "required": ["sender", "receiver", "cards"]
          }
        }
      }
    },
    "trickPlayPhase": {
      "type": "object",
      "required": ["phaseNumber", "type", "tricks"],
      "properties": {
        "phaseNumber": { "type": "integer" },
        "type": { "const": "TRICK_PLAY" },
        "initialLead": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3
        },
        "tricks": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "items": { "$ref": "#/definitions/card_list" }
        }
      }
    }
  }
}